local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "InvisibleGUI"
gui.ResetOnSpawn = false
gui.Parent = player.PlayerGui

-- Frame principal
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0,120,0,120)
frame.Position = UDim2.new(0.4,0,0.4,0)
frame.BackgroundColor3 = Color3.fromRGB(40,40,40)
frame.BackgroundTransparency = 0.4
frame.Parent = gui

-- Botão INV
local inv = Instance.new("TextButton")
inv.Size = UDim2.new(0,70,0,70)
inv.Position = UDim2.new(0.5,-35,0.5,-35)
inv.BackgroundColor3 = Color3.fromRGB(120,120,120)
inv.BackgroundTransparency = 0.3
inv.Text = "INV"
inv.TextScaled = true
inv.TextColor3 = Color3.new(1,1,1)
inv.Parent = frame

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(1,0)
corner.Parent = inv

-- Cadeado
local lock = Instance.new("TextButton")
lock.Size = UDim2.new(0,22,0,22)
lock.Position = UDim2.new(1,-26,0,4)
lock.Text = "🔓"
lock.BackgroundTransparency = 1
lock.TextScaled = true
lock.Parent = frame

local dragEnabled = true

-- Sistema de drag (frame apenas)
local UIS = game:GetService("UserInputService")
local dragging
local dragStart
local startPos

frame.InputBegan:Connect(function(input)
	if not dragEnabled then return end
	
	if input.UserInputType == Enum.UserInputType.MouseButton1 
	or input.UserInputType == Enum.UserInputType.Touch then
		
		dragging = true
		dragStart = input.Position
		startPos = frame.Position
		
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement 
	or input.UserInputType == Enum.UserInputType.Touch) then
		
		local delta = input.Position - dragStart
		
		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

-- Cadeado
lock.MouseButton1Click:Connect(function()
	dragEnabled = not dragEnabled
	
	if dragEnabled then
		lock.Text = "🔓"
	else
		lock.Text = "🔒"
	end
end)

-- Invisibilidade
local invisible = false

inv.MouseButton1Click:Connect(function()
	invisible = not invisible
	
	for _,v in pairs(char:GetDescendants()) do
		if v:IsA("BasePart") then
			if invisible then
				v.LocalTransparencyModifier = 0.6
				v.Transparency = 1
			else
				v.LocalTransparencyModifier = 0
				v.Transparency = 0
			end
		end
		
		if v:IsA("Decal") then
			v.Transparency = invisible and 1 or 0
		end
	end
end)
